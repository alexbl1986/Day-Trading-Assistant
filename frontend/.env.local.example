# Copy to .env.local. These defaults work for local dev against `uv run langgraph dev`.

# Server-side only: where the Next.js /api proxy forwards LangGraph requests.
LANGGRAPH_API_URL=http://localhost:2024
# Server-side only: LangSmith key for a LangSmith-hosted deployment. Leave empty for local dev.
LANGSMITH_API_KEY=
# Browser-exposed: where useStream points. Defaults to /api if unset.
NEXT_PUBLIC_API_URL=http://localhost:3000/api
